rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - role: string (required, 'admin' or 'employee')
    //   - name: string (required)
    //   - phone: string (required)
    //   - adminId: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: clients
    // Document ID: {clientId}
    // Fields:
    //   - adminId: string (required)
    //   - name: string (required)
    //   - phone: string (required)
    //   - address: string (required)
    //   - monthlyFee: number (required)
    //   - dueDate: number (required)
    //   - visitDays: list of strings (required)
    //   - employeeId: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: payments
    // Document ID: {paymentId}
    // Fields:
    //   - adminId: string (required)
    //   - clientId: string (required)
    //   - amount: number (required)
    //   - date: timestamp (required)
    //   - month: number (required)
    //   - year: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'servincg@gmail.com' ||
        request.auth.uid == '9p1a2d2PGKg0vWCyj7wygUpJRwR2' ||
        (getUserData() != null && getUserData().email == 'servincg@gmail.com')
      );
    }

    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'admin';
    }

    function isEmployee() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'employee';
    }

    function isManager() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'manager';
    }

    function isClient() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'client';
    }

    function getAdminId() {
      let data = getUserData();
      return data != null ? data.adminId : null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'role', 'name', 'phone', 'adminId', 'createdAt', 'updatedAt', 'password', 'whatsappSettings', 'customProducts', 'lastLocation', 'lastLocationAt', 'clientId', 'email', 'subscriptionStatus', 'subscriptionExpiresAt', 'adminSubscriptionExpired']) &&
             isValidString(data.uid, 1, 128) &&
             (data.role == 'admin' || data.role == 'employee' || data.role == 'manager' || data.role == 'client') &&
             isValidString(data.name, 1, 100) &&
             (!('phone' in data) || isValidString(data.phone, 0, 50)) &&
             isValidString(data.adminId, 1, 128) &&
             (!('clientId' in data) || isValidString(data.clientId, 1, 128)) &&
             (!('email' in data) || isValidString(data.email, 5, 200)) &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus == 'trial' || data.subscriptionStatus == 'active' || data.subscriptionStatus == 'expired') &&
             (!('subscriptionExpiresAt' in data) || data.subscriptionExpiresAt is timestamp) &&
             (!('adminSubscriptionExpired' in data) || data.adminSubscriptionExpired is bool) &&
             (!('password' in data) || isValidString(data.password, 6, 128)) &&
             (!('whatsappSettings' in data) || data.whatsappSettings is map) &&
             (!('customProducts' in data) || data.customProducts is list) &&
             (!('lastLocation' in data) || data.lastLocation is map) &&
             (!('lastLocationAt' in data) || data.lastLocationAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             data.createdAt is timestamp;
    }

    function isValidClient(data) {
      return hasOnlyAllowedFields(['adminId', 'name', 'phone', 'address', 'monthlyFee', 'dueDate', 'baseDueDay', 'visitDays', 'employeeId', 'createdAt', 'cpfCnpj', 'extraVisits', 'lastVisitDate']) &&
             isValidString(data.adminId, 1, 128) &&
             isValidString(data.name, 0, 100) &&
             (!('phone' in data) || isValidString(data.phone, 0, 50)) &&
             (!('address' in data) || isValidString(data.address, 0, 500)) &&
             (!('monthlyFee' in data) || (data.monthlyFee is number && data.monthlyFee >= 0)) &&
             (!('dueDate' in data) || data.dueDate is string || data.dueDate is number) &&
             (!('baseDueDay' in data) || data.baseDueDay is number || data.baseDueDay == null) &&
             (!('visitDays' in data) || (data.visitDays is list && data.visitDays.size() <= 7)) &&
             (!('extraVisits' in data) || data.extraVisits is list) &&
             (!('lastVisitDate' in data) || data.lastVisitDate is timestamp) &&
             (!('employeeId' in data) || data.employeeId == null || isValidString(data.employeeId, 0, 128)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('cpfCnpj' in data) || isValidString(data.cpfCnpj, 0, 20));
    }

    function isValidPayment(data) {
      return hasOnlyAllowedFields(['adminId', 'clientId', 'amount', 'date', 'month', 'year', 'previousDueDate', 'refMonth', 'refYear']) &&
             isValidString(data.adminId, 1, 128) &&
             isValidString(data.clientId, 1, 128) &&
             data.amount is number && data.amount >= 0 &&
             data.date is timestamp &&
             data.month is number && data.month >= 1 && data.month <= 12 &&
             data.year is number && data.year >= 2000 &&
             (!('previousDueDate' in data) || data.previousDueDate == null || data.previousDueDate is string) &&
             (!('refMonth' in data) || (data.refMonth is number && data.refMonth >= 1 && data.refMonth <= 12)) &&
             (!('refYear' in data) || (data.refYear is number && data.refYear >= 2000));
    }

    function isValidVisit(data) {
      return hasOnlyAllowedFields(['adminId', 'clientId', 'date', 'notes', 'employeeId', 'photoUrl', 'location']) &&
             isValidString(data.adminId, 1, 128) &&
             isValidString(data.clientId, 1, 128) &&
             data.date is timestamp &&
             isValidString(data.notes, 0, 5000) &&
             (!('employeeId' in data) || data.employeeId == null || isValidString(data.employeeId, 0, 128)) &&
             (!('photoUrl' in data) || data.photoUrl == null || data.photoUrl is string) &&
             (!('location' in data) || data.location == null || data.location is map);
    }

    function isValidOneOffJob(data) {
      return hasOnlyAllowedFields(['adminId', 'clientName', 'clientPhone', 'address', 'date', 'price', 'employeeId', 'status', 'returnDate', 'report', 'createdAt', 'updatedAt']) &&
             isValidString(data.adminId, 1, 128) &&
             isValidString(data.clientName, 1, 200) &&
             (!('clientPhone' in data) || data.clientPhone == null || isValidString(data.clientPhone, 0, 50)) &&
             isValidString(data.address, 1, 500) &&
             data.date is string &&
             data.price is number &&
             (!('employeeId' in data) || data.employeeId == null || isValidString(data.employeeId, 0, 128)) &&
             (data.status == 'pending' || data.status == 'completed' || data.status == 'needs_return') &&
             (!('returnDate' in data) || data.returnDate == null || data.returnDate is string) &&
             (!('report' in data) || data.report == null || data.report is string) &&
             (!('createdAt' in data) || data.createdAt == null || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /users/{userId} {
      // Allow read if the user is reading their own profile, or if an admin is reading an employee they created,
      // or if they share the same adminId.
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isOwner(userId) || 
        (resource != null && isAdmin() && resource.data.adminId == request.auth.uid) ||
        (resource != null && getAdminId() == resource.data.adminId)
      );

      // Allow create if:
      // 1. A new admin is registering themselves (adminId == uid)
      // 2. An admin is creating an employee/manager/client (adminId == admin's uid)
      // 3. A manager is creating an employee/client (adminId == manager's adminId)
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && request.resource.data.uid == userId && (
        (request.resource.data.role == 'admin' && request.resource.data.adminId == request.auth.uid && request.auth.uid == userId) ||
        ((request.resource.data.role == 'employee' || request.resource.data.role == 'manager' || request.resource.data.role == 'client') && (isAdmin() || isManager()) && request.resource.data.adminId == getAdminId()) ||
        isSuperAdmin()
      );

      // Allow update if:
      // 1. Admin updating their own profile
      // 2. Admin updating their employee's profile
      // Employees cannot update their own profiles (or we could allow it but restrict role/adminId)
      allow update: if (isAuthenticated() && request.auth.token.email == 'servincg@gmail.com') || (isAuthenticated() && (
        isSuperAdmin() ||
        (isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid && request.resource.data.adminId == resource.data.adminId && request.resource.data.createdAt == resource.data.createdAt && (
          (request.resource.data.role == resource.data.role && isAdmin() && resource.data.adminId == request.auth.uid) ||
          (request.resource.data.role == resource.data.role && isOwner(userId))
        ))
      ));

      allow delete: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && resource.data.adminId == request.auth.uid && resource.data.uid != request.auth.uid));
    }

    match /clients/{clientId} {
      // Read: Admins and Managers can read all their clients. Employees can only read clients assigned to them.
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId()) ||
        (isEmployee() && resource.data.adminId == getAdminId() && resource.data.employeeId == request.auth.uid) ||
        (isClient() && resource.data.adminId == getAdminId() && resource.id == getUserData().clientId)
      );

      allow create: if isAuthenticated() && isValidClient(request.resource.data) && (
        isSuperAdmin() ||
        (isAdmin() && request.resource.data.adminId == request.auth.uid) ||
        (isManager() && request.resource.data.adminId == getAdminId())
      );
      
      allow update: if isAuthenticated() && isValidClient(request.resource.data) && resource.data.adminId == request.resource.data.adminId && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt) && (
        isSuperAdmin() ||
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId()) ||
        (isEmployee() && resource.data.adminId == getAdminId() && resource.data.employeeId == request.auth.uid)
      );
      
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId())
      );
    }

    match /payments/{paymentId} {
      // Admins and managers can read/write. Employees can read.
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        ((isManager() || isEmployee()) && resource.data.adminId == getAdminId()) ||
        (isClient() && resource.data.adminId == getAdminId() /* maybe add && resource.data.clientId == getUserData().clientId here later */)
      );
      allow create: if isAuthenticated() && isValidPayment(request.resource.data) && (
        (isAdmin() && request.resource.data.adminId == request.auth.uid) ||
        (isManager() && request.resource.data.adminId == getAdminId())
      );
      allow update: if isAuthenticated() && isValidPayment(request.resource.data) && resource.data.adminId == request.resource.data.adminId && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId())
      );
      allow delete: if isAuthenticated() && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId())
      );
    }

    match /visits/{visitId} {
      allow read: if isAuthenticated() && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        ((isEmployee() || isManager()) && resource.data.adminId == getAdminId()) ||
        // clients can see visits if it's their client ID or they share admin ID
        (isClient() && resource.data.adminId == getAdminId())
      );
      allow create: if isAuthenticated() && isValidVisit(request.resource.data) && (
        (isAdmin() && request.resource.data.adminId == request.auth.uid) ||
        ((isEmployee() || isManager()) && request.resource.data.adminId == getAdminId())
      );
      allow update: if isAuthenticated() && isValidVisit(request.resource.data) && (
        (isAdmin() && resource.data.adminId == request.auth.uid && request.resource.data.adminId == resource.data.adminId) ||
        ((isEmployee() || isManager()) && resource.data.adminId == getAdminId() && request.resource.data.adminId == resource.data.adminId)
      );
      allow delete: if isAuthenticated() && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        ((isEmployee() || isManager()) && resource.data.adminId == getAdminId())
      );
    }

    match /oneoffjobs/{jobId} {
      allow read: if isAuthenticated() && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId()) ||
        (isEmployee() && resource.data.adminId == getAdminId() && resource.data.employeeId == request.auth.uid)
      );
      allow create: if isAuthenticated() && isValidOneOffJob(request.resource.data) && (
        (isAdmin() && request.resource.data.adminId == request.auth.uid) ||
        (isManager() && request.resource.data.adminId == getAdminId())
      );
      allow update: if isAuthenticated() && isValidOneOffJob(request.resource.data) && resource.data.adminId == request.resource.data.adminId && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId()) ||
        (isEmployee() && resource.data.adminId == getAdminId() && resource.data.employeeId == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (
        (isAdmin() && resource.data.adminId == request.auth.uid) ||
        (isManager() && resource.data.adminId == getAdminId())
      );
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated(); // Should probably check if chat belongs to them or same adminId, simplified for now
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if false;
    }
  }
}
